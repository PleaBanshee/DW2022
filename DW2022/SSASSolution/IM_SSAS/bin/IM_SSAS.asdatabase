                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Length_Measured_Indicator" msprop:Description="'No length measured' or 'Length measured'." msprop:design-time-name="b4acecf3-0810-4b22-affc-049173eab17d" msprop:DbColumnName="Length_Measured_Indicator" msprop:FriendlyName="Length Measured Indicator">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Width_Measured_Indicator" msprop:Description="'No width measured' or 'Width measured'" msprop:design-time-name="67135689-23c9-4e17-b21f-ad3a25d748e3" msprop:DbColumnName="Width_Measured_Indicator" msprop:FriendlyName="Width Measured Indicator">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Full_Units_Counted_Indicator" msprop:Description="'No full units counted' or 'Full units counted'" msprop:design-time-name="a59513e0-ffcc-4d7e-9f3c-4e44323cdb34" msprop:DbColumnName="Full_Units_Counted_Indicator" msprop:FriendlyName="Full Units Counted Indicator">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Material_Scrapped_Indicator" msprop:Description="'No material scrapped' or 'Material Scrapped'" msprop:design-time-name="7213ac17-17dd-4822-b3e1-e07b8c46859f" msprop:DbColumnName="Material_Scrapped_Indicator" msprop:FriendlyName="Material Scrapped Indicator">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Unit_Price_Available_Indicator" msprop:Description="'No unit price available' or 'Unit price available'" msprop:design-time-name="9e6e5029-f85c-4034-b9c4-4d771f636f4e" msprop:DbColumnName="Unit_Price_Available_Indicator" msprop:FriendlyName="Unit Price Available Indicator">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="VAT_Percentage" msprop:Description="For example &quot;14%&quot; or &quot;15%&quot;" msprop:design-time-name="8c0d09a8-2988-44f5-9e83-45aecdd9052e" msprop:DbColumnName="VAT_Percentage" msprop:FriendlyName="VAT Percentage">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="20" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Effective_Date" msprop:design-time-name="8c26a381-d144-4992-afa5-50d70c4c9469" msprop:DbColumnName="Effective_Date" msprop:FriendlyName="Effective_Date" type="xs:dateTime" />
                      <xs:element name="Import_Action" msprop:design-time-name="b6572cdb-4c09-4de7-a7b9-6ad3064bbaf8" msprop:DbColumnName="Import_Action" msprop:FriendlyName="Import_Action">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="10" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="IBPT_ID" msprop:design-time-name="15a287b5-93c3-495d-941f-04e488b7eea0" msprop:DbColumnName="IBPT_ID" type="xs:int" minOccurs="0" />
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="dbo_Stock_Take_Fact" msprop:design-time-name="9767c141-7004-4c9a-b50e-6162666c0290" msprop:FriendlyName="Stock Take Fact" msprop:DbSchemaName="dbo" msprop:DbTableName="Stock_Take_Fact" msprop:TableType="Table">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="Stock_Take_Date_Key" msprop:design-time-name="621ef26c-8ede-4705-b89b-a5669a96a4f2" msprop:DbColumnName="Stock_Take_Date_Key" msprop:FriendlyName="Stock Take Year Key" type="xs:int" />
                      <xs:element name="Material_Item_Key" msprop:design-time-name="61fa957b-7bbb-46f9-a731-e112aa35edbc" msprop:DbColumnName="Material_Item_Key" msprop:FriendlyName="Material Item Key" type="xs:int" />
                      <xs:element name="Stock_Take_Indicators_Key" msprop:design-time-name="39d5e261-409e-4451-bc46-3778b38933ce" msprop:DbColumnName="Stock_Take_Indicators_Key" msprop:FriendlyName="Stock Take Indicators Key" type="xs:int" />
                      <xs:element name="Stock_Take_Transaction_ID" msprop:Description="Supernatural key created to link back to the source system - has the year and source line number" msprop:design-time-name="32c18aae-432f-4791-b0ce-81d2cb950982" msprop:DbColumnName="Stock_Take_Transaction_ID" msprop:FriendlyName="Stock Take Transaction ID">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="20" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Material_Length_Measured_m" msprop:Description="Length of the item measured in meter" msprop:design-time-name="7363a374-ab24-4daa-b70c-14e118f3de0e" msprop:DbColumnName="Material_Length_Measured_m" msprop:FriendlyName="Material Length Measured (m)" type="xs:decimal" minOccurs="0" />
                      <xs:element name="Material_Width_Measured_m" msprop:Description="Width of the item measured in meter" msprop:design-time-name="b9a3f541-7b4f-458b-a5ac-6a3a17a616aa" msprop:DbColumnName="Material_Width_Measured_m" msprop:FriendlyName="Material Width Measured (m)" type="xs:decimal" minOccurs="0" />
                      <xs:element name="Material_Full_Units_Counted" msprop:Description="Number of material item full units counted" msprop:design-time-name="cfa55e22-3b7c-4253-ae22-b0d1df4678ee" msprop:DbColumnName="Material_Full_Units_Counted" msprop:FriendlyName="Material Full Units Counted" type="xs:short" minOccurs="0" />
                      <xs:element name="Material_Quantity_Scrapped" msprop:Description="Quantity of the item that was scrapped after counting" msprop:design-time-name="55f99750-3527-4689-a187-c41bc222af1f" msprop:DbColumnName="Material_Quantity_Scrapped" msprop:FriendlyName="Material Quantity Scrapped" type="xs:double" minOccurs="0" />
