  <MdxScripts>
    <MdxScript dwd:design-time-name="cf3c3da5-5ec8-497c-b352-8c414fc5c39a">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Material Percentage Scrapped]
 AS [Measures].[Material Quantity Scrapped]/[Measures].[Material Quantity Counted], 
FORMAT_STRING = "Percent", 
NON_EMPTY_BEHAVIOR = { [Material Quantity Scrapped] }, 
VISIBLE = 1 ,  DISPLAY_FOLDER = 'Material Percentages' ,  ASSOCIATED_MEASURE_GROUP = 'Stock Take Fact'  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="c15ea092-6e8f-4c4b-b4b1-06e4a0e5da79">
      <ID>KPI</ID>
      <Name>KPI Material Scrapped</Name>
      <AssociatedMeasureGroupID>Stock Take Fact</AssociatedMeasureGroupID>
      <Value>[Measures].[Material Quantity Scrapped]</Value>
      <Goal>0</Goal>
      <Status>
Case  
  When KpiValue("KPI Material Scrapped") - KpiGoal("KPI Material Scrapped") = 0 Then 1  
  When KpiValue("KPI Material Scrapped") - KpiGoal("KPI Material Scrapped") &gt; 5 Then -1  
  Else 0  
End</Status>
      <Trend>
Case  
  When IsEmpty(ParallelPeriod([Year].[Year].[Year],1, [Year].[Year])) Then 0  
  When [Measures].[Material Quantity Scrapped] &gt; (ParallelPeriod([Year].[Year].[Year],1, [Year].[Year]), [Measures].[Material Quantity Scrapped])  
    Then 1  
  When [Measures].[Material Quantity Scrapped] = (ParallelPeriod([Year].[Year].[Year],1, [Year].[Year]), [Measures].[Material Quantity Scrapped])  
    Then 0  
  Else -1  
End</Trend>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Smiley Face</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>